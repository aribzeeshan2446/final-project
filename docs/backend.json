
{
  "entities": {
    "VerificationResult": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "VerificationResult",
      "type": "object",
      "description": "Represents a single instance of a factual accuracy check performed on selected web text.",
      "properties": {
        "id": { "type": "string" },
        "originalText": { "type": "string" },
        "sourceUrl": { "type": "string", "format": "uri" },
        "verdict": { "type": "string" },
        "suggestedCorrection": { "type": "string" },
        "reasoning": { "type": "string" },
        "recommendedSearchQuery": { "type": "string" },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "reliability": { "type": "string", "enum": ["High", "Medium", "Mixed"] }
            }
          }
        },
        "checkedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "originalText", "verdict", "checkedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profile root."
        }
      },
      {
        "path": "/users/{userId}/verificationResults/{verificationResultId}",
        "definition": {
          "entityName": "VerificationResult",
          "schema": { "$ref": "#/backend/entities/VerificationResult" },
          "description": "Individual factual verification results."
        }
      }
    ]
  }
}
